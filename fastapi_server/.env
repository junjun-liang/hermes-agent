# .env 示例文件

# ========== 服务基础配置 ==========
APP_NAME=Hermes-Agent API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ========== Agent 核心配置 ==========
DEFAULT_MODEL=qwen3.5-plus-2026-04-20
MAX_ITERATIONS=90
TOOL_DELAY=1.0
SAVE_TRAJECTORIES=false

# 启用的工具集（逗号分隔，不填则使用默认）
# ENABLED_TOOLSETS=web,file,code_execution,vision

# 禁用的工具集（逗号分隔）
DISABLED_TOOLSETS=messaging,homeassistant,cron

# ========== 会话管理 ==========
SESSION_TIMEOUT=3600
MAX_SESSIONS_PER_USER=10
# SESSION_DB_PATH=/path/to/state.db

# ========== 资源限制 ==========
MAX_CONCURRENT_AGENTS=10
MAX_REQUEST_TIMEOUT=300
MAX_REQUEST_SIZE=10485760

# ========== 认证与安全 ==========
# API Keys（逗号分隔）
# 开发环境：不设置 API Key（允许所有请求）
# 生产环境：设置有效的 API Key，例如：API_KEYS=xK7_9Hj2mN5pQ8rT3vW6yZ1aB4cD7eF0gI2jK5lM8nO
API_KEYS=

# JWT 配置
JWT_SECRET_KEY=your-super-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15

# ========== CORS 配置 ==========
# 生产环境应设置具体域名
CORS_ORIGINS=http://localhost:3000,https://your-app.com

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=/var/log/hermes-agent/api.log
LOG_FORMAT=json

# ========== 速率限制 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/1

# ========== 监控与指标 ==========
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
# SENTRY_DSN=https://your-sentry-dsn

# ========== Redis 配置（可选） ==========
# REDIS_URL=redis://localhost:6379/0

# ========== LLM API Keys ==========
DASHSCOPE_API_KEY=sk-8bae4e7ec6bd4a2a8c081037a602aea3
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 工具 API Keys（可选） ==========
# FIRECRAWL_API_KEY=fc-xxx
# EXA_API_KEY=exa-xxx
